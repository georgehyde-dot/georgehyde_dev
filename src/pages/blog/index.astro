---
/**
 * src/pages/blog/index.astro — Public blog post listing.
 *
 * SSR only (prerender = false). Reads the BLOG_POSTS KV namespace via the
 * Cloudflare adapter runtime context and renders published posts newest-first.
 * A single KV list() call suffices because PostMetadata is stored on each key
 * (see @decision DEC-KV-001 in src/lib/kv-store.ts).
 *
 * @decision DEC-BLOG-001
 * @title SSR blog list page with Cloudflare runtime env access
 * @status accepted
 * @rationale The blog list must be dynamic (post count changes after deploy).
 *   prerender = false forces Cloudflare Worker invocation on every request,
 *   giving the page access to Astro.locals.runtime.env where KV bindings live.
 *   No client-side JS is required — the page is plain server-rendered HTML,
 *   consistent with the project's vanilla-JS, minimal-dependency philosophy.
 */

export const prerender = false;

import type { Runtime } from "@astrojs/cloudflare";
import type { Env } from "../../lib/kv-store";
import { listPublishedPosts, type PostMetadata } from "../../lib/kv-store";

// Access Cloudflare KV via the adapter runtime context.
// Astro.locals.runtime.env is typed via the Runtime<Env> generic.
const runtime = (Astro.locals as Runtime<Env>).runtime;
const env = runtime.env;

let posts: PostMetadata[] = [];
let error: string | null = null;

try {
  posts = await listPublishedPosts(env);
} catch (e) {
  error = e instanceof Error ? e.message : "Failed to load posts.";
}

const formatDate = (iso: string): string => {
  const d = new Date(iso);
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Blog — George Hyde" />
    <title>Blog — George Hyde</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="container">
      <nav class="nav">
        <a href="/" class="back-link">
          <svg class="back-icon" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
            ></path>
          </svg>
          Home
        </a>
      </nav>

      <header class="page-header">
        <h1 class="page-title">Blog</h1>
      </header>

      {
        error ? (
          <p class="error-message">Error loading posts: {error}</p>
        ) : posts.length === 0 ? (
          <p class="empty-state">No posts yet.</p>
        ) : (
          <ol class="post-list">
            {posts.map((post) => (
              <li class="post-item">
                <a href={`/blog/${post.slug}`} class="post-link">
                  <span class="post-title">{post.title}</span>
                  <time
                    class="post-date"
                    datetime={post.createdAt}
                  >
                    {formatDate(post.createdAt)}
                  </time>
                </a>
              </li>
            ))}
          </ol>
        )
      }
    </main>

    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Oxygen,
          Ubuntu,
          Cantarell,
          sans-serif;
        background: #0a0a0a;
        color: #e5e5e5;
        line-height: 1.6;
        min-height: 100vh;
      }

      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }

      /* Navigation */
      .nav {
        margin-bottom: 2.5rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        color: #71717a;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.15s ease;
      }

      .back-link:hover {
        color: #e5e5e5;
      }

      .back-icon {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
      }

      /* Page header */
      .page-header {
        margin-bottom: 2.5rem;
        border-bottom: 1px solid rgba(63, 63, 70, 0.5);
        padding-bottom: 1.5rem;
      }

      .page-title {
        font-size: 2rem;
        font-weight: 600;
        color: #f4f4f5;
        letter-spacing: -0.02em;
      }

      /* Empty / error states */
      .empty-state {
        color: #71717a;
        font-size: 1rem;
        padding: 2rem 0;
      }

      .error-message {
        color: #f87171;
        font-size: 0.875rem;
        padding: 1rem 0;
      }

      /* Post list */
      .post-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .post-item {
        border-bottom: 1px solid rgba(63, 63, 70, 0.3);
      }

      .post-item:first-child {
        border-top: none;
      }

      .post-link {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        padding: 1.125rem 0;
        text-decoration: none;
        color: inherit;
        transition: color 0.15s ease;
      }

      .post-link:hover .post-title {
        color: #4ade80;
      }

      .post-title {
        font-size: 1rem;
        font-weight: 500;
        color: #e5e5e5;
        transition: color 0.15s ease;
        flex: 1;
        min-width: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .post-date {
        font-size: 0.8125rem;
        color: #71717a;
        white-space: nowrap;
        flex-shrink: 0;
      }

      @media (max-width: 480px) {
        .container {
          padding: 2rem 1.25rem;
        }

        .post-link {
          flex-direction: column;
          gap: 0.25rem;
        }

        .post-title {
          white-space: normal;
          overflow: visible;
        }
      }
    </style>
  </body>
</html>
